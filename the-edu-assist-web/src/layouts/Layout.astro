---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="TheEduAssist - Turn Your Knowledge Into a Launch-Ready Online Course" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/jpeg" href="/logo.jpg" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@700;800&display=swap" rel="stylesheet">
	</head>
	<body class="font-sans selection:bg-indigo-100 selection:text-indigo-700">
		<Navbar />
		<slot />

    <script>
      // Global intersection observer for reveal animations
      function initScrollReveals() {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');

              // Handle counters
              const counters = entry.target.querySelectorAll('.counter');
              counters.forEach(counter => {
                if (counter.classList.contains('counter-started')) return;
                counter.classList.add('counter-started');

                const targetText = counter.getAttribute('data-target');
                if (!targetText) return;
                const target = parseInt(targetText);
                if (isNaN(target)) return;

                let count = 0;
                const duration = 2000; // 2 seconds
                const increment = target / (duration / 16);

                const updateCount = () => {
                  count += increment;
                  if (count < target) {
                    (counter as HTMLElement).innerText = Math.ceil(count).toString();
                    requestAnimationFrame(updateCount);
                  } else {
                    (counter as HTMLElement).innerText = target.toString();
                  }
                };
                updateCount();
              });
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal-left, .reveal-right, .reveal-up').forEach(el => {
          observer.observe(el);
        });
      }

      // Initial load
      initScrollReveals();

      // For Astro view transitions if they are used
      document.addEventListener('astro:after-swap', initScrollReveals);
    </script>
	</body>
</html>

<style is:global>
	:root {
		--accent: 79, 70, 229;
		--accent-light: 224, 231, 255;
		--accent-dark: 49, 46, 129;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
	}

  /* Global Reveal Animation Styles */
  .reveal-left, .reveal-right, .reveal-up {
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-left { transform: translateX(-50px); }
  .reveal-right { transform: translateX(50px); }
  .reveal-up { transform: translateY(50px); }

  .revealed {
    opacity: 1 !important;
    transform: translate(0, 0) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-left, .reveal-right, .reveal-up {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
