---
interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const {
	title,
	description = "TheEduAssist helps experts, coaches, and consultants design, build, and launch high-impact online courses on Kajabi and other LMS platforms.",
	image = "/favicon.svg", // Default image if none provided
	canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://theeduassist-92ca4.web.app").href,
} = Astro.props;

import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

const siteName = "TheEduAssist";
const author = "TheEduAssist Team";
const twitterHandle = "@theeduassist"; // Placeholder if unknown
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Global Metadata -->
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="keywords" content="online course design, course creation agency, Kajabi setup, curriculum planning, e-learning consultant, LMS implementation, TheEduAssist" />
		<meta name="author" content={author} />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site || "https://theeduassist-92ca4.web.app")} />
		<meta property="og:site_name" content={siteName} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.site || "https://theeduassist-92ca4.web.app")} />
		{twitterHandle && <meta property="twitter:site" content={twitterHandle} />}

		<!-- Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": siteName,
			"url": "https://theeduassist-92ca4.web.app",
			"logo": "https://theeduassist-92ca4.web.app/favicon.svg",
			"description": description,
			"sameAs": [
				// Add social media links here if available
			]
		})} />

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#F9FAFB] text-slate-900 font-sans selection:bg-indigo-100 selection:text-indigo-700">
		<Navbar />
		<slot />

    <script>
      // Global intersection observer for reveal animations
      function initScrollReveals() {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');

              // Handle counters
              const counters = entry.target.querySelectorAll('.counter');
              counters.forEach(counter => {
                if (counter.classList.contains('counter-started')) return;
                counter.classList.add('counter-started');

                const targetText = counter.getAttribute('data-target');
                if (!targetText) return;
                const target = parseInt(targetText);
                if (isNaN(target)) return;

                let count = 0;
                const duration = 2000; // 2 seconds
                const increment = target / (duration / 16);

                const updateCount = () => {
                  count += increment;
                  if (count < target) {
                    (counter as HTMLElement).innerText = Math.ceil(count).toString();
                    requestAnimationFrame(updateCount);
                  } else {
                    (counter as HTMLElement).innerText = target.toString();
                  }
                };
                updateCount();
              });
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal-left, .reveal-right, .reveal-up').forEach(el => {
          observer.observe(el);
        });
      }

      // Initial load
      initScrollReveals();

      // For Astro view transitions if they are used
      document.addEventListener('astro:after-swap', initScrollReveals);
    </script>
	</body>
</html>

<style is:global>
	:root {
		--accent: 79, 70, 229;
		--accent-light: 224, 231, 255;
		--accent-dark: 49, 46, 129;
	}
	html {
		font-family: 'Inter', system-ui, sans-serif;
		scroll-behavior: smooth;
	}

  /* Global Reveal Animation Styles */
  .reveal-left, .reveal-right, .reveal-up {
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-left { transform: translateX(-50px); }
  .reveal-right { transform: translateX(50px); }
  .reveal-up { transform: translateY(50px); }

  .revealed {
    opacity: 1 !important;
    transform: translate(0, 0) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-left, .reveal-right, .reveal-up {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
