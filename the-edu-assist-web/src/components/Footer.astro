---
const currentYear = new Date().getFullYear();

const services = [
  { name: "Course Strategy", href: "/services#services" },
  { name: "Curriculum Design", href: "/services#services" },
  { name: "Kajabi Setup", href: "/services#services" },
  { name: "LMS Implementation", href: "/services#services" },
  { name: "Launch Support", href: "/services#services" },
];

const company = [
  { name: "Home", href: "/#top" },
  { name: "About Us", href: "/about" },
  { name: "Services", href: "/services" },
  { name: "Pricing", href: "/#pricing" },
  { name: "How It Works", href: "/#how-it-works" },
];

const socials = [
  {
    name: "Facebook",
    href: "#",
    sr: "Facebook",
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>`
  },
  {
    name: "Instagram",
    href: "#",
    sr: "Instagram",
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.012 3.855.06 1.061.048 1.791.222 2.427.458 1.06.333 1.791.746 2.427 1.383.637.637 1.05 1.367 1.383 2.427.236.636.41 1.366.458 2.427.048 1.071.06 1.425.06 3.855 0 2.43-.012 2.784-.06 3.855-.048 1.061-.222 1.791-.458 2.427-.333 1.06-.746 1.791-1.383 2.427-.637.637-1.367 1.05-2.427 1.383-.636.236-1.366.41-2.427.458-1.071.048-1.425.06-3.855.06-2.43 0-2.784-.012-3.855-.06-1.061-.048-1.791-.222-2.427-.458-1.06-.333-1.791-.746-2.427-1.383-.637-.637-1.05-1.367-1.383-2.427-.236-.636-.41-1.366-.458-2.427-.048-1.071-.06-1.425-.06-3.855 0-2.43.012-2.784.06-3.855.048-1.061.222-1.791.458-2.427.333-1.06.746-1.791 1.383-2.427.637-.637 1.367-1.05 2.427-1.383.636-.236 1.366.41 2.427-.458 1.071-.048 1.425-.06 3.855-.06zm-1.1 1.1c-2.4 0-2.745.01-3.693.054-.93.04-1.435.193-1.77.323-.448.173-.768.381-1.106.718-.337.337-.545.658-.718 1.106-.13.335-.283.84-.323 1.77-.043.947-.054 1.292-.054 3.692s.01 2.745.054 3.693c.04.93.193 1.435.323 1.77.173.448.381.768.718 1.106.337.337.658.545 1.106.718.335.13.84.283 1.77.323.947.043 1.292.054 3.692.054s2.745-.01 3.693-.054c.93-.04 1.435-.193 1.77-.323.448-.173.768-.381 1.106-.718.337-.337.658.545 1.106.718.335.13.84.283 1.77.323.947.043 1.292.054 3.692.054zM12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16.7a4.538 4.538 0 110-9.076 4.538 4.538 0 010 9.076zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`
  },
  {
    name: "LinkedIn",
    href: "#",
    sr: "LinkedIn",
    icon: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>`
  }
];
---

<footer class="bg-white dark:bg-slate-950 transition-colors duration-300 relative overflow-hidden">
  <!-- Top Gradient Divider -->
  <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-slate-200 dark:via-slate-800 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 py-16">
    <!-- CTA Section -->
    <div class="mb-20 reveal-up">
      <div class="relative p-8 md:p-12 rounded-3xl bg-slate-50 dark:bg-slate-900/50 border border-slate-100 dark:border-slate-800 overflow-hidden text-center group">
        <!-- Background Accents -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-indigo-500/5 rounded-full blur-3xl group-hover:bg-indigo-500/10 transition-colors duration-500"></div>
        <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-blue-500/5 rounded-full blur-3xl group-hover:bg-blue-500/10 transition-colors duration-500"></div>

        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white mb-6 tracking-tight">
          Ready to build your online course? <br class="hidden md:block" />
          <span class="text-indigo-600 dark:text-indigo-400">Let's make it happen.</span>
        </h2>
        <p class="text-lg text-slate-500 dark:text-slate-400 mb-8 max-w-2xl mx-auto">
          Join experts who have transformed their knowledge into high-impact digital products.
        </p>
        <a href="/#contact" class="inline-flex items-center justify-center px-8 py-4 bg-indigo-600 text-white font-bold rounded-2xl transition-all duration-300 hover:bg-indigo-700 hover:scale-105 shadow-lg shadow-indigo-200 dark:shadow-indigo-900/20">
          Get Started Now
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16 reveal-up" style="transition-delay: 100ms">
      <!-- Brand Column -->
      <div class="space-y-8">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white font-bold text-xl transition-transform duration-300 group-hover:scale-110">
            E
          </div>
          <span class="text-2xl font-black tracking-tight text-slate-900 dark:text-white">TheEduAssist</span>
        </a>
        <p class="text-slate-500 dark:text-slate-400 leading-relaxed max-w-xs">
          Turning your unique expertise into world-class digital learning experiences with premium design and strategy.
        </p>
        <div class="flex gap-4">
          {socials.map((social) => (
            <a
              href={social.href}
              class="w-10 h-10 rounded-xl bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800 flex items-center justify-center text-slate-600 dark:text-slate-400 transition-all duration-300 hover:text-slate-900 dark:hover:text-white hover:scale-105 hover:border-slate-200 dark:hover:border-slate-700"
              aria-label={social.sr}
            >
              <Fragment set:html={social.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Company Links -->
      <nav aria-label="Company navigation">
        <h3 class="text-sm font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-8">Company</h3>
        <ul class="space-y-4">
          {company.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-slate-500 dark:text-slate-400 transition duration-300 hover:text-slate-900 dark:hover:text-white hover:scale-105 inline-block origin-left"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Services Links -->
      <nav aria-label="Services navigation">
        <h3 class="text-sm font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-8">Services</h3>
        <ul class="space-y-4">
          {services.map((service) => (
            <li>
              <a
                href={service.href}
                class="text-slate-500 dark:text-slate-400 transition duration-300 hover:text-slate-900 dark:hover:text-white hover:scale-105 inline-block origin-left"
              >
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact Info -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-widest text-slate-900 dark:text-white mb-8">Get in Touch</h3>
        <address class="not-italic space-y-6">
          <div class="flex items-start gap-4 text-slate-500 dark:text-slate-400">
            <div class="w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-1">Email Us</p>
              <a href="mailto:Info@theeduassist.com" class="text-slate-900 dark:text-white font-medium hover:text-indigo-600 dark:hover:text-indigo-400 transition-all duration-300 hover:scale-105 inline-block origin-left">
                Info@theeduassist.com
              </a>
            </div>
          </div>
          <div class="flex items-start gap-4 text-slate-500 dark:text-slate-400">
            <div class="w-10 h-10 rounded-xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-1">Location</p>
              <p class="text-slate-900 dark:text-white font-medium">
                Remote First Agency
              </p>
            </div>
          </div>
        </address>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 border-t border-slate-100 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-slate-500 dark:text-slate-400 reveal-up" style="transition-delay: 200ms">
      <p>© {currentYear} TheEduAssist. All rights reserved.</p>
      <div class="flex gap-8">
        <a href="#" class="hover:text-slate-900 dark:hover:text-white transition-all duration-300 hover:scale-105">Privacy Policy</a>
        <a href="#" class="hover:text-slate-900 dark:hover:text-white transition-all duration-300 hover:scale-105">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
