---
const features = [
  { title: "Expert Curriculum Design", description: "Structured for maximum retention and impact." },
  { title: "AI-Powered Workflows", description: "Speeding up production without sacrificing quality." },
  { title: "LMS Implementation", description: "Full technical setup on Kajabi, Thinkific, or custom platforms." },
  { title: "Course Launch Support", description: "Strategies to get your first 100 students." },
  { title: "Better Learner Engagement", description: "Interactive elements that keep students coming back." },
  { title: "Faster Production", description: "Go from idea to launch in weeks, not months." }
];
---
<section id="why-choose-us" class="py-24 md:py-32 bg-white">
   <div class="max-w-7xl mx-auto px-6">
     <div class="flex flex-col lg:flex-row gap-16 items-center">
        <div class="lg:w-1/3 reveal-left">
          <h2 class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-4">Why Us</h2>
          <h3 class="text-4xl font-bold text-slate-900 mb-6">The Premium Choice for Serious Creators</h3>
          <p class="text-lg text-slate-500 mb-8">We don't just build courses; we build learning assets that grow your business and authority.</p>
          <div class="flex items-center gap-4 text-slate-900 font-bold">
             <div class="flex -space-x-2">
               {[1,2,3,4].map(i => <div class="w-10 h-10 rounded-full border-2 border-white bg-slate-200"></div>)}
             </div>
             <span>Joined by 50+ Experts</span>
          </div>
        </div>
        <div class="lg:w-2/3 grid sm:grid-cols-2 gap-6">
           {features.map((f, i) => (
             <div class="p-8 rounded-3xl bg-slate-50 border border-slate-100 hover:bg-white hover:shadow-xl transition-all duration-300 reveal-right" style={`transition-delay: ${i * 100}ms`}>
                <div class="w-12 h-12 rounded-xl bg-white flex items-center justify-center text-indigo-600 shadow-sm mb-6">
                   <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h4 class="text-xl font-bold text-slate-900 mb-2">{f.title}</h4>
                <p class="text-slate-500 leading-relaxed">{f.description}</p>
             </div>
           ))}
        </div>
     </div>
   </div>
</section>
