---
const features = [
  { title: "Expert Curriculum Design", description: "Structured for maximum retention and impact." },
  { title: "AI-Powered Workflows", description: "Speeding up production without sacrificing quality." },
  { title: "LMS Implementation", description: "Full technical setup on Kajabi, Thinkific, or custom platforms." },
  { title: "Course Launch Support", description: "Strategies to get your first 100 students." },
  { title: "Better Learner Engagement", description: "Interactive elements that keep students coming back." },
  { title: "Faster Production", description: "Go from idea to launch in weeks, not months." }
];
---
<section id="why-choose-us" class="py-24 md:py-32 bg-white dark:bg-slate-950 transition-colors duration-300">
   <div class="max-w-7xl mx-auto px-6">
     <div class="flex flex-col lg:flex-row gap-16 items-center">
        <div class="lg:w-1/3 reveal-left">
          <h2 class="inline-flex items-center text-indigo-600 dark:text-indigo-400 font-bold tracking-widest uppercase text-sm mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            Why Us
          </h2>
          <h3 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6 leading-tight after:mt-4 after:block after:w-20 after:h-1.5 after:rounded-full after:bg-gradient-to-r after:from-indigo-600 after:to-violet-500 dark:text-white">
            <span class="bg-gradient-to-r from-indigo-600 to-violet-500 bg-clip-text text-transparent">The Premium Choice</span> for Serious Creators
          </h3>
          <p class="text-lg text-slate-500 dark:text-slate-400 mb-8">We don't just build courses; we build learning assets that grow your business and authority.</p>
          <div class="flex items-center gap-4 text-slate-900 dark:text-white font-bold">
             <div class="flex -space-x-2">
               {[1,2,3,4].map(i => <div class="w-10 h-10 rounded-full border-2 border-white dark:border-slate-800 bg-slate-200 dark:bg-slate-700"></div>)}
             </div>
             <span>Joined by 50+ Experts</span>
          </div>
        </div>
        <div class="lg:w-2/3 grid sm:grid-cols-2 gap-6">
           {features.map((f, i) => (
             <div class="p-8 rounded-3xl bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800 hover:bg-white dark:hover:bg-slate-800 hover:shadow-2xl dark:hover:shadow-indigo-500/10 hover:-translate-y-2 transition-all duration-500 reveal-right group" style={`transition-delay: ${i * 100}ms`}>
                <div class="w-12 h-12 rounded-xl bg-white dark:bg-slate-800 flex items-center justify-center text-indigo-600 dark:text-indigo-400 shadow-sm mb-6 group-hover:scale-110 transition-transform duration-500">
                   <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
                <h4 class="text-xl font-bold text-slate-900 dark:text-white mb-2">{f.title}</h4>
                <p class="text-slate-500 dark:text-slate-400 leading-relaxed">{f.description}</p>
             </div>
           ))}
        </div>
     </div>
   </div>
</section>
