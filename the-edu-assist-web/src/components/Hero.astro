---
---
<section id="top" class="relative pt-32 pb-24 md:pt-48 md:pb-40 overflow-hidden">
  <!-- Animated Background Blobs -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10">
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-indigo-100/40 dark:bg-indigo-900/20 blur-[160px] animate-blob"></div>
    <div class="absolute bottom-[10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-blue-100/40 dark:bg-blue-900/20 blur-[140px] animate-blob animation-delay-2000"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 text-center">
    <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-indigo-50 dark:bg-indigo-900/30 border border-indigo-100 dark:border-indigo-800 text-indigo-600 dark:text-indigo-400 text-sm font-semibold mb-8 animate-fade-in">
      Course Building & Launch Agency
    </div>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 dark:text-white mb-8 animate-fade-up">
      Turn Your Knowledge Into a <br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-blue-600 to-indigo-600 bg-[length:200%_auto] animate-gradient-text">Launch-Ready Course</span>
    </h1>
    <p class="text-xl md:text-2xl text-slate-600 dark:text-slate-400 max-w-3xl mx-auto mb-12 animate-fade-up animation-delay-200">
      We help experts, coaches, and consultants design, build, and launch high-impact online courses on Kajabi and other LMS platforms.
    </p>
    <div class="flex flex-col sm:flex-row gap-6 justify-center animate-fade-up animation-delay-300">
      <a href="/#services" class="px-10 py-5 bg-indigo-600 text-white font-bold rounded-2xl hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-200 dark:shadow-indigo-900/20 hover:shadow-indigo-300 hover:-translate-y-1">
        Start Your Course Build
      </a>
      <a href="/about" class="px-10 py-5 bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 font-bold rounded-2xl border border-slate-200 dark:border-slate-800 hover:border-slate-300 dark:hover:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all hover:-translate-y-1">
        How We Can Help
      </a>
    </div>

    <!-- Dashboard Mockup -->
    <div class="mt-24 relative animate-fade-up animation-delay-500 animate-float">
      <div class="relative mx-auto max-w-5xl group hover:scale-[1.02] transition-transform duration-700 ease-out">
         <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-blue-50 rounded-[2.5rem] blur opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-500"></div>
         <div class="relative bg-white dark:bg-slate-900 rounded-[2rem] shadow-2xl border border-slate-100 dark:border-slate-800 overflow-hidden">
            <div class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-100 dark:border-slate-800 px-6 py-4 flex items-center gap-3">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                <div class="w-3 h-3 rounded-full bg-green-400"></div>
              </div>
              <div class="h-6 w-64 bg-white dark:bg-slate-700 rounded-lg border border-slate-200 dark:border-slate-700 ml-4"></div>
            </div>
            <div class="relative bg-slate-50 dark:bg-[#020617] p-6 md:p-20 lg:p-24 overflow-hidden">
               <!-- Premium Desk Texture and High-End Lighting -->
               <div class="absolute inset-0 opacity-[0.04] dark:opacity-[0.08] pointer-events-none bg-[url('/images/wood-pattern.png')] mix-blend-overlay"></div>
               <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/5 via-transparent to-white/10 pointer-events-none"></div>
               <div class="absolute -top-1/2 -left-1/4 w-full h-full bg-white/10 blur-[120px] rounded-full pointer-events-none"></div>

               <div class="relative flex flex-col md:flex-row items-center justify-center gap-12 lg:gap-0">
                  <!-- Accessories Left -->
                  <div class="hidden lg:flex flex-col gap-24 items-end pr-8">
                     <!-- Plant -->
                     <div class="relative w-36 h-48 transform -rotate-2 hover:rotate-0 transition-transform duration-1000 ease-out group/plant">
                        <svg viewBox="0 0 100 120" class="w-full h-full drop-shadow-[0_15px_30px_rgba(0,0,0,0.15)]">
                           <defs>
                              <linearGradient id="potGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                 <stop offset="0%" style="stop-color:#f8fafc" />
                                 <stop offset="100%" style="stop-color:#cbd5e1" />
                              </linearGradient>
                              <linearGradient id="leafGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                 <stop offset="0%" style="stop-color:#4ade80" />
                                 <stop offset="100%" style="stop-color:#16a34a" />
                              </linearGradient>
                           </defs>
                           <!-- Pot with depth -->
                           <path d="M30 115 L70 115 L78 65 L22 65 Z" fill="url(#potGrad)" />
                           <ellipse cx="50" cy="65" rx="29" ry="5" fill="#94a3b8" opacity="0.3" />
                           <path d="M22 65 L78 65 L81 55 L19 55 Z" fill="#e2e8f0" />
                           <!-- Realistic Leaves -->
                           <path d="M50 55 C15 35 -5 10 48 2 C58 20 62 40 50 55" fill="url(#leafGrad)" class="animate-pulse" style="animation-duration: 4s" />
                           <path d="M50 55 C85 35 105 10 52 2 C42 20 38 40 50 55" fill="#15803d" />
                           <path d="M50 55 C35 25 30 5 65 -2 C75 20 70 40 50 55" fill="#22c55e" transform="rotate(-20 50 55)" />
                        </svg>
                     </div>
                     <!-- Books -->
                     <div class="flex flex-col -space-y-3 items-end">
                        <div class="w-40 h-10 bg-gradient-to-r from-indigo-700 to-indigo-600 rounded-sm shadow-xl transform rotate-1 flex items-center px-4 border-l-4 border-indigo-900/20">
                           <div class="w-full h-[1px] bg-white/20"></div>
                        </div>
                        <div class="w-44 h-10 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-sm shadow-xl transform -rotate-1 flex items-center px-4 border-l-4 border-slate-300 dark:border-slate-900">
                           <div class="w-1/2 h-1.5 bg-slate-100 dark:bg-slate-700 rounded-full"></div>
                        </div>
                        <div class="w-42 h-10 bg-slate-800 dark:bg-slate-700 rounded-sm shadow-2xl transform rotate-1 flex items-center px-4 border-l-4 border-slate-950">
                           <div class="w-full h-[1px] bg-white/5"></div>
                        </div>
                     </div>
                  </div>

                  <!-- Main Laptop -->
                  <div class="relative z-10 w-full max-w-2xl transform hover:-translate-y-2 transition-all duration-1000 ease-out group/laptop">
                     <!-- Laptop Lid/Screen with Realistic Bezel -->
                     <div class="relative aspect-[16/10] bg-[#1a1a1a] rounded-[1.5rem] p-1 shadow-[0_40px_100px_-20px_rgba(0,0,0,0.5)] border-[1px] border-white/10">
                        <div class="w-full h-full bg-[#0a0a0a] rounded-[1.2rem] p-4 flex flex-col relative overflow-hidden">
                           <!-- Screen Gloss/Reflection -->
                           <div class="absolute inset-0 bg-gradient-to-tr from-white/0 via-white/[0.03] to-white/[0.08] pointer-events-none z-10"></div>

                           <div class="w-full h-full bg-white dark:bg-[#0f172a] rounded-lg overflow-hidden flex flex-col relative">
                              <!-- Dashboard UI Header -->
                              <div class="h-12 border-b border-slate-100 dark:border-slate-800/50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md flex items-center justify-between px-6 z-20">
                                 <div class="flex items-center gap-4">
                                    <div class="w-24 h-3 bg-indigo-600/20 rounded-full"></div>
                                    <div class="w-16 h-3 bg-slate-200 dark:bg-slate-700/50 rounded-full"></div>
                                 </div>
                                 <div class="flex gap-3">
                                    <div class="w-6 h-6 rounded-lg bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center">
                                       <div class="w-2.5 h-2.5 rounded-full bg-indigo-500"></div>
                                    </div>
                                    <div class="w-6 h-6 rounded-full bg-slate-100 dark:bg-slate-800"></div>
                                 </div>
                              </div>

                              <div class="flex-1 flex overflow-hidden">
                                 <!-- Dashboard Sidebar -->
                                 <div class="w-1/4 border-r border-slate-100 dark:border-slate-800/50 bg-slate-50/50 dark:bg-slate-900/50 p-4 space-y-5">
                                    <div class="h-3 w-full bg-indigo-600/10 rounded-full"></div>
                                    <div class="space-y-4 pt-2">
                                       <div class="h-2 w-full bg-slate-100 dark:bg-slate-800 rounded-full"></div>
                                       <div class="h-2 w-5/6 bg-slate-100 dark:bg-slate-800 rounded-full"></div>
                                       <div class="h-2 w-full bg-indigo-600/20 rounded-full"></div>
                                       <div class="h-2 w-4/6 bg-slate-100 dark:bg-slate-800 rounded-full"></div>
                                    </div>
                                    <div class="pt-6">
                                       <div class="aspect-square w-full bg-gradient-to-br from-indigo-500/10 to-blue-500/10 rounded-2xl border border-indigo-100/50 dark:border-indigo-800/30 flex items-center justify-center">
                                          <div class="w-1/2 h-1/2 bg-indigo-500/20 rounded-full blur-xl animate-pulse"></div>
                                       </div>
                                    </div>
                                 </div>

                                 <!-- Dashboard Main Content -->
                                 <div class="flex-1 p-6 overflow-y-auto bg-white dark:bg-[#0f172a] scrollbar-hide">
                                    <div class="flex justify-between items-end mb-8">
                                       <div>
                                          <div class="text-[11px] font-black text-slate-900 dark:text-white mb-1 uppercase tracking-wider">Course Dashboard</div>
                                          <div class="text-[9px] text-slate-500 font-medium">Mastering Digital Influence • Module 04</div>
                                       </div>
                                       <div class="text-right">
                                          <div class="text-[9px] text-indigo-600 font-bold mb-2 uppercase tracking-tight">Progress: 84%</div>
                                          <div class="w-24 h-2 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                                             <div class="w-[84%] h-full bg-gradient-to-r from-indigo-600 to-violet-600 shadow-[0_0_8px_rgba(79,70,229,0.4)]"></div>
                                          </div>
                                       </div>
                                    </div>

                                    <!-- Premium Video Player -->
                                    <div class="aspect-video bg-[#020617] rounded-2xl relative group/player overflow-hidden mb-8 shadow-2xl border border-white/5">
                                       <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-black/20"></div>
                                       <!-- Play Button -->
                                       <div class="absolute inset-0 flex items-center justify-center">
                                          <div class="w-16 h-16 bg-white/10 backdrop-blur-xl rounded-full flex items-center justify-center border border-white/30 group-hover/player:scale-110 group-hover/player:bg-indigo-600 transition-all duration-500 shadow-[0_0_40px_rgba(0,0,0,0.3)]">
                                             <svg class="w-8 h-8 text-white ml-1.5" fill="currentColor" viewBox="0 0 20 20"><path d="M4.5 14V6L14.5 10L4.5 14Z"></path></svg>
                                          </div>
                                       </div>
                                       <!-- Interactive Progress Mock -->
                                       <div class="absolute bottom-5 left-6 right-6 flex items-center gap-4 opacity-80">
                                          <div class="flex-1 h-1.5 bg-white/20 rounded-full overflow-hidden">
                                             <div class="w-[45%] h-full bg-indigo-500 relative">
                                                <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3 h-3 bg-white rounded-full shadow-lg"></div>
                                             </div>
                                          </div>
                                          <div class="text-[8px] text-white font-mono">12:45 / 28:00</div>
                                       </div>
                                    </div>

                                    <!-- Stats Grid with Depth -->
                                    <div class="grid grid-cols-2 gap-6">
                                       <div class="p-4 rounded-2xl bg-slate-50 dark:bg-slate-800/40 border border-slate-100 dark:border-slate-800/60 shadow-sm">
                                          <div class="flex items-center gap-2 mb-2">
                                             <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                                             <div class="text-[8px] font-bold text-slate-400 uppercase tracking-widest">Enrollment</div>
                                          </div>
                                          <div class="text-lg font-black text-slate-900 dark:text-white">2,842</div>
                                       </div>
                                       <div class="p-4 rounded-2xl bg-indigo-50/30 dark:bg-indigo-500/5 border border-indigo-100/50 dark:border-indigo-500/20 shadow-sm relative overflow-hidden">
                                          <div class="absolute -right-2 -bottom-2 w-12 h-12 bg-indigo-500/10 rounded-full blur-xl"></div>
                                          <div class="flex items-center gap-2 mb-2">
                                             <div class="w-1.5 h-1.5 rounded-full bg-indigo-500"></div>
                                             <div class="text-[8px] font-bold text-slate-400 uppercase tracking-widest">Revenue</div>
                                          </div>
                                          <div class="text-lg font-black text-indigo-600 dark:text-indigo-400">$48.2k</div>
                                       </div>
                                    </div>
                                 </div>
                              </div>
                           </div>
                        </div>
                     </div>
                     <!-- Metallic Laptop Base with Perspective -->
                     <div class="relative w-[110%] -ml-[5%] h-4 bg-gradient-to-b from-[#333] via-[#222] to-[#111] rounded-b-[2rem] shadow-[0_20px_40px_-10px_rgba(0,0,0,0.4)]">
                        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-1.5 bg-[#444] rounded-b-xl border-t border-white/5"></div>
                        <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-[95%] h-1 bg-black/40 blur-sm rounded-full"></div>
                     </div>
                     <!-- Soft Reflection on Desk -->
                     <div class="absolute -bottom-16 left-1/2 -translate-x-1/2 w-[90%] h-20 bg-indigo-600/10 blur-[60px] rounded-full pointer-events-none group-hover/laptop:bg-indigo-600/20 transition-all duration-1000"></div>
                  </div>

                  <!-- Accessories Right -->
                  <div class="flex md:flex-col lg:flex-col items-center gap-20 pl-8">
                     <!-- Ceramic Coffee Mug with Realistic Shadow -->
                     <div class="relative group/mug cursor-default">
                        <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-16 h-4 bg-black/10 blur-md rounded-full"></div>
                        <svg viewBox="0 0 100 100" class="w-24 h-24 drop-shadow-2xl transform hover:scale-105 hover:-rotate-3 transition-all duration-700">
                           <defs>
                              <linearGradient id="mugGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                 <stop offset="0%" style="stop-color:#ffffff" />
                                 <stop offset="100%" style="stop-color:#f1f5f9" />
                              </linearGradient>
                           </defs>
                           <path d="M30 25 L70 25 L73 85 C73 95 63 100 50 100 C37 100 27 95 27 85 Z" fill="url(#mugGrad)" />
                           <path d="M70 38 C88 38 96 52 84 65 C78 72 71 65 71 65" fill="none" stroke="#f1f5f9" stroke-width="8" stroke-linecap="round" />
                           <!-- Internal depth -->
                           <ellipse cx="50" cy="25" rx="20" ry="4" fill="#1e293b" opacity="0.05" />
                        </svg>
                        <!-- Steam Animation -->
                        <div class="absolute -top-6 left-1/2 -translate-x-1/2 flex gap-1 opacity-0 group-hover/mug:opacity-40 transition-opacity duration-1000">
                           <div class="w-0.5 h-6 bg-indigo-400 rounded-full blur-[1px] animate-bounce" style="animation-delay: 0.2s"></div>
                           <div class="w-0.5 h-8 bg-indigo-300 rounded-full blur-[1px] animate-bounce" style="animation-delay: 0.4s"></div>
                           <div class="w-0.5 h-6 bg-indigo-400 rounded-full blur-[1px] animate-bounce"></div>
                        </div>
                     </div>

                     <!-- Notebook & Premium Pen -->
                     <div class="relative w-36 h-48 bg-white dark:bg-slate-800 rounded-xl shadow-[0_20px_50px_rgba(0,0,0,0.15)] border-l-[10px] border-indigo-600 transform rotate-3 hover:rotate-1 transition-all duration-1000 p-6 group/note">
                        <div class="space-y-4">
                           <div class="h-[1.5px] w-full bg-slate-100 dark:bg-slate-700/50"></div>
                           <div class="h-[1.5px] w-full bg-slate-100 dark:bg-slate-700/50"></div>
                           <div class="h-[1.5px] w-5/6 bg-indigo-100 dark:bg-indigo-900/30"></div>
                           <div class="h-[1.5px] w-full bg-slate-100 dark:bg-slate-700/50"></div>
                           <div class="h-[1.5px] w-2/3 bg-slate-100 dark:bg-slate-700/50"></div>
                        </div>
                        <!-- Realistic Metallic Pen -->
                        <div class="absolute -right-6 top-12 w-2.5 h-36 bg-gradient-to-r from-slate-800 via-slate-700 to-slate-900 rounded-full shadow-2xl transform -rotate-12 group-hover/note:-rotate-6 transition-all duration-700 border-x border-white/5">
                           <div class="absolute top-4 left-1/2 -translate-x-1/2 w-1.5 h-6 bg-indigo-500/40 rounded-full blur-sm"></div>
                           <div class="absolute top-2 w-full h-1 bg-white/10"></div>
                        </div>
                     </div>
                  </div>
               </div>
            </div>
         </div>
      </div>
      <!-- Floating shapes -->
      <div class="absolute -top-12 -right-12 w-32 h-32 bg-yellow-400/10 rounded-full blur-2xl animate-pulse"></div>
      <div class="absolute -bottom-12 -left-12 w-40 h-40 bg-indigo-600/10 rounded-full blur-3xl animate-pulse animation-delay-2000"></div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 { animation-delay: 2s; }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes gradient-text {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .animate-fade-in { animation: fade-in 1s ease-out forwards; }
  .animate-fade-up { opacity: 0; animation: fade-up 1s ease-out forwards; }
  .animate-gradient-text { animation: gradient-text 3s linear infinite; }

  @media (prefers-reduced-motion: reduce) {
    .animate-blob, .animate-fade-in, .animate-fade-up, .animate-gradient-text {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  .animation-delay-200 { animation-delay: 0.2s; }
  .animation-delay-300 { animation-delay: 0.3s; }
  .animation-delay-500 { animation-delay: 0.5s; }
</style>
