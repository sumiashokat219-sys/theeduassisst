---
---
<section class="relative pt-20 pb-32 overflow-hidden">
  <!-- Soft background gradient -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-30">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-200 blur-[120px]"></div>
    <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-blue-100 blur-[100px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 border border-indigo-100 text-indigo-600 text-sm font-medium mb-6">
          <span class="relative flex h-2 w-2 mr-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
          </span>
          Course Design Agency
        </div>
        <h1 class="text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 leading-tight mb-6">
          Turn Your Knowledge Into a <span class="text-indigo-600">Launch-Ready</span> Online Course
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed mb-10 max-w-xl">
          We help creators, coaches, educators, and training businesses plan, structure, design, and launch professional online courses that are easier for learners to follow.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#services" class="px-8 py-4 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 transition-all shadow-lg shadow-indigo-200 hover:shadow-indigo-300 text-center">
            Start Your Course Build
          </a>
          <a href="#how-it-works" class="px-8 py-4 bg-white text-slate-700 font-semibold rounded-xl border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all text-center">
            See How It Works
          </a>
        </div>
      </div>

      <div class="relative">
        <!-- Dashboard Mockup -->
        <div class="bg-white rounded-2xl shadow-2xl border border-slate-100 overflow-hidden p-4 rotate-1 lg:rotate-2 hover:rotate-0 transition-transform duration-500">
          <div class="flex items-center gap-2 mb-4 px-2">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
            <div class="ml-4 h-6 w-48 bg-slate-100 rounded-md"></div>
          </div>

          <div class="grid grid-cols-12 gap-4">
            <!-- Sidebar -->
            <div class="col-span-3 space-y-3">
              <div class="h-4 w-full bg-indigo-50 rounded-md"></div>
              <div class="h-4 w-2/3 bg-slate-50 rounded-md"></div>
              <div class="h-4 w-full bg-slate-50 rounded-md"></div>
              <div class="h-4 w-3/4 bg-slate-50 rounded-md"></div>
              <div class="mt-8 h-4 w-full bg-indigo-50 rounded-md"></div>
              <div class="h-4 w-4/5 bg-slate-50 rounded-md"></div>
            </div>

            <!-- Main Content -->
            <div class="col-span-9 space-y-4">
              <!-- Video Lesson Card -->
              <div class="aspect-video bg-slate-900 rounded-lg relative flex items-center justify-center overflow-hidden">
                <div class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
                  <div class="w-0 h-0 border-t-[10px] border-t-transparent border-l-[16px] border-l-white border-b-[10px] border-b-transparent ml-1"></div>
                </div>
                <div class="absolute bottom-4 left-4 right-4 h-1 bg-white/30 rounded-full">
                  <div class="w-1/3 h-full bg-indigo-500 rounded-full"></div>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <!-- Course Outline Card -->
                <div class="p-4 rounded-xl border border-slate-100 bg-slate-50/50">
                   <div class="flex items-center justify-between mb-3">
                     <div class="h-3 w-20 bg-slate-300 rounded"></div>
                     <div class="h-3 w-8 bg-indigo-200 rounded"></div>
                   </div>
                   <div class="space-y-2">
                     <div class="h-2 w-full bg-slate-200 rounded"></div>
                     <div class="h-2 w-full bg-slate-200 rounded"></div>
                     <div class="h-2 w-2/3 bg-slate-200 rounded"></div>
                   </div>
                </div>

                <!-- Progress Card -->
                <div class="p-4 rounded-xl border border-slate-100 bg-indigo-50/30">
                  <div class="h-3 w-16 bg-indigo-300 rounded mb-4"></div>
                  <div class="relative h-16 w-16 mx-auto">
                    <svg class="h-full w-full" viewBox="0 0 36 36">
                      <path class="text-indigo-100" stroke-width="3" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                      <path class="text-indigo-600" stroke-width="3" stroke-dasharray="75, 100" stroke-linecap="round" stroke="currentColor" fill="none" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                    </svg>
                    <div class="absolute inset-0 flex items-center justify-center text-[10px] font-bold text-indigo-700">75%</div>
                  </div>
                </div>
              </div>

              <!-- Quiz/Worksheet Card -->
              <div class="p-4 rounded-xl border border-indigo-100 bg-white shadow-sm flex items-center gap-4">
                <div class="w-10 h-10 rounded-lg bg-indigo-100 flex items-center justify-center text-indigo-600">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15h6"/><path d="M9 19h6"/><path d="M9 11h1"/></svg>
                </div>
                <div class="flex-1">
                  <div class="h-3 w-32 bg-slate-200 rounded mb-2"></div>
                  <div class="h-2 w-20 bg-slate-100 rounded"></div>
                </div>
                <div class="h-8 w-20 bg-indigo-600 rounded-lg"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Floating Decorative Elements -->
        <div class="absolute -top-6 -right-6 w-24 h-24 bg-blue-100 rounded-2xl -z-10 animate-pulse"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-indigo-50 rounded-full -z-10"></div>
      </div>
    </div>
  </div>
</section>
