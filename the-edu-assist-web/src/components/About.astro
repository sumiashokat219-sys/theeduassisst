---
const features = [
  {
    title: "Professional Course Design",
    description: "We create clear learning paths that improve student understanding and course completion.",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
  },
  {
    title: "AI-Powered Workflow",
    description: "We use modern AI tools to speed up course development while maintaining quality.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  },
  {
    title: "End-to-End Support",
    description: "From planning to launch, we guide you through every step of the process.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
  },
  {
    title: "Client-Focused Approach",
    description: "Every course is customized to match your audience, goals, and teaching style.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
  }
];
---
<section id="about" class="py-24 bg-white relative overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute top-0 left-0 w-full h-full pointer-events-none -z-10">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-indigo-50 rounded-full blur-3xl opacity-50 -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-1/2 h-1/2 bg-blue-50/50 rounded-full blur-3xl translate-x-1/4 translate-y-1/4"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center mb-24">
      <div class="reveal-left">
        <h2 class="text-indigo-600 font-semibold tracking-wide uppercase text-sm mb-3">About TheEduAssist</h2>
        <h3 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 leading-tight">
          Helping experts transform their knowledge into engaging, structured online courses.
        </h3>
        <div class="space-y-4 text-lg text-slate-600 leading-relaxed">
          <p>
            At TheEduAssist, we help creators, coaches, educators, consultants, and training businesses turn their ideas, documents, videos, and expertise into professional online courses.
          </p>
          <p>
            Our mission is to simplify the entire course creation process—from curriculum planning and instructional design to learning management system setup and course launch—so our clients can focus on sharing their knowledge while we handle the structure and technical details.
          </p>
          <p>
            We combine instructional design expertise with modern AI tools to create learning experiences that are engaging, organized, and easy to follow.
          </p>
        </div>
      </div>

      <div class="relative reveal-right">
        <div class="bg-indigo-600/5 rounded-3xl p-8 md:p-12 border border-indigo-100 flex items-center justify-center">
          <!-- Illustration representing course creation/online learning -->
          <svg viewBox="0 0 400 300" class="w-full h-auto drop-shadow-2xl" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="40" y="40" width="320" height="220" rx="20" fill="white" />
            <rect x="40" y="40" width="320" height="40" rx="20" fill="#EEF2FF" />
            <circle cx="70" cy="60" r="6" fill="#818CF8" />
            <circle cx="90" cy="60" r="6" fill="#A5B4FC" />
            <circle cx="110" cy="60" r="6" fill="#C7D2FE" />

            <!-- Course Layout Mockup -->
            <rect x="70" y="100" width="100" height="60" rx="8" fill="#818CF8" />
            <rect x="185" y="100" width="145" height="12" rx="6" fill="#E2E8F0" />
            <rect x="185" y="125" width="100" height="12" rx="6" fill="#E2E8F0" />
            <rect x="185" y="150" width="120" height="12" rx="6" fill="#E2E8F0" />

            <rect x="70" y="180" width="260" height="12" rx="6" fill="#F1F5F9" />
            <rect x="70" y="205" width="260" height="12" rx="6" fill="#F1F5F9" />
            <rect x="70" y="230" width="180" height="12" rx="6" fill="#F1F5F9" />

            <!-- Floating element (AI/Magic) -->
            <g class="animate-bounce" style="animation-duration: 3s;">
               <path d="M320 60L340 80L320 100L300 80L320 60Z" fill="#F59E0B" opacity="0.8" />
            </g>
          </svg>
        </div>
        <!-- Decorative blobs -->
        <div class="absolute -top-6 -right-6 w-24 h-24 bg-blue-100 rounded-full -z-10 mix-blend-multiply filter blur-xl opacity-70 animate-pulse"></div>
        <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-indigo-100 rounded-full -z-10 mix-blend-multiply filter blur-xl opacity-70"></div>
      </div>
    </div>

    <div class="text-center mb-16 reveal-up">
      <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">Why Choose Us</h3>
      <div class="w-16 h-1 bg-indigo-600 mx-auto rounded-full"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map((feature, i) => (
        <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group reveal-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="w-14 h-14 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={feature.icon} />
            </svg>
          </div>
          <h4 class="text-xl font-bold text-slate-900 mb-3">{feature.title}</h4>
          <p class="text-slate-600 leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
