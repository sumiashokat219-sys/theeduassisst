---
const services = [
  {
    title: "Course creation and curriculum design",
    description: "Expert planning and structuring of your educational content.",
    icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
  },
  {
    title: "Kajabi course setup",
    description: "Complete technical configuration of your Kajabi platform.",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
  },
  {
    title: "LMS implementation",
    description: "Setup and optimization of any Learning Management System.",
    icon: "M19 21V5a2 2 0 00-2 2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
  },
  {
    title: "Content conversion",
    description: "Turning slides, videos, and PDFs into structured lessons.",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
  },
  {
    title: "AI-powered course support",
    description: "Leveraging AI for faster content generation and learner support.",
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0012 18.75V19a2 2 0 11-4 0v-.25c0-1.035-.32-2.04-.924-2.85l-.548-.547z"
  },
  {
    title: "Funnels and automation",
    description: "Automating your sales and onboarding for a hands-off experience.",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
  }
];
---
<section id="services" class="py-24 bg-[#F9FAFB]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16 reveal-up">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Our Services</h2>
      <p class="text-slate-600 max-w-2xl mx-auto text-lg">
        Tailored solutions to help you design, build, and launch a professional e-learning business.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {services.map((service, i) => (
        <div class="bg-white p-10 rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all group reveal-up" style={`transition-delay: ${i * 100}ms`}>
          <div class="w-12 h-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-4">{service.title}</h3>
          <p class="text-slate-600 leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
