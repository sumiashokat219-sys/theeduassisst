---
const mainLinks = [
  { name: 'Home', href: '/#top' },
  { name: 'Services', href: '/#services' },
  { name: 'Pricing', href: '/#pricing' },
  { name: 'About', href: '/about' },
];

const dropdownLinks = [
  { name: 'How It Works', href: '/#how-it-works' },
  { name: 'Why Choose Us', href: '/#why-choose-us' },
  { name: 'Testimonials', href: '/#testimonials' },
  { name: 'FAQ', href: '/#faq' },
  { name: 'Contact', href: '/#contact' },
];

const allLinks = [...mainLinks, ...dropdownLinks];
import ThemeToggle from './ThemeToggle.astro';
import Logo from './Logo.astro';
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 border-b border-transparent dark:border-slate-800/50 [&.is-scrolled]:bg-white/70 dark:[&.is-scrolled]:bg-slate-900/70 [&.is-scrolled]:backdrop-blur-xl [&.is-scrolled]:border-slate-100/50 dark:[&.is-scrolled]:border-slate-800/50 [&.is-scrolled]:shadow-lg [&.is-scrolled]:shadow-slate-200/20 dark:[&.is-scrolled]:shadow-slate-950/20" id="navbar">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-slate-900 dark:text-white flex items-center gap-2 group">
      <Logo size={40} class="group-hover:scale-110 transition-transform duration-300" />
      <span class="tracking-tight">TheEduAssist</span>
    </a>

    <!-- Desktop Menu -->
    <div class="hidden lg:flex items-center gap-1">
      {mainLinks.map(link => (
        <a
          href={link.href}
          class="nav-link px-4 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition-all relative group"
          data-href={link.href}
        >
          {link.name}
          <span class="absolute bottom-1 left-4 right-4 h-0.5 bg-indigo-600 transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left active-indicator"></span>
        </a>
      ))}

      <!-- More Dropdown -->
      <div class="relative group dropdown-container">
        <button
          class="px-4 py-2 text-sm text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition-all flex items-center gap-1 group/btn"
          aria-haspopup="true"
          aria-expanded="false"
        >
          More
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover/btn:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>

        <div class="absolute top-full right-0 mt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible translate-y-2 group-hover:translate-y-0 transition-all duration-300 z-[60] focus-within:opacity-100 focus-within:visible focus-within:translate-y-0" role="menu">
          <div class="bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border border-slate-200/50 dark:border-slate-800/50 rounded-2xl shadow-2xl shadow-slate-200/50 dark:shadow-slate-950/50 overflow-hidden p-2">
            {dropdownLinks.map(link => (
              <a
                href={link.href}
                role="menuitem"
                class="nav-link flex items-center px-4 py-3 text-sm text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-slate-50 dark:hover:bg-slate-800/50 rounded-xl transition-all font-medium group/item"
                data-href={link.href}
              >
                {link.name}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-auto opacity-0 -translate-x-2 group-hover/item:opacity-100 group-hover/item:translate-x-0 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="hidden lg:flex items-center gap-4">
       <ThemeToggle />
       <a href="/#contact" class="px-6 py-2.5 bg-gradient-to-r from-indigo-600 to-blue-600 text-white font-bold rounded-xl hover:shadow-lg hover:shadow-indigo-200 transition-all hover:-translate-y-0.5 active:translate-y-0 text-sm">
        Book a Free Consultation
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <div class="flex items-center gap-2 lg:hidden">
      <ThemeToggle />
      <button class="p-2 text-slate-600 dark:text-slate-300 relative z-50" id="mobile-menu-button" aria-label="Toggle Menu">
        <div class="w-6 h-5 relative flex flex-col justify-between">
          <span class="w-full h-0.5 bg-current transition-all duration-500 origin-left" id="hamburger-top"></span>
          <span class="w-full h-0.5 bg-current transition-all duration-500" id="hamburger-mid"></span>
          <span class="w-full h-0.5 bg-current transition-all duration-500 origin-left" id="hamburger-bottom"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="lg:hidden fixed inset-0 bg-white/80 dark:bg-slate-900/80 backdrop-blur-2xl z-40 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] translate-x-full" id="mobile-menu">
    <div class="flex flex-col h-full pt-24 pb-12 px-8 overflow-y-auto">
      <div class="flex flex-col gap-4">
        {allLinks.map(link => (
          <a href={link.href} class="mobile-nav-link text-2xl font-bold text-slate-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors border-b border-slate-100 dark:border-slate-800 pb-4">
            {link.name}
          </a>
        ))}
      </div>
      <div class="mt-auto pt-8">
        <a href="/#contact" class="mobile-nav-link block w-full py-5 bg-gradient-to-r from-indigo-600 to-blue-600 text-white font-bold rounded-2xl text-center text-lg shadow-xl shadow-indigo-100">
          Book a Free Consultation
        </a>
        <div class="mt-8 text-center text-slate-400 text-sm">
          © 2024 TheEduAssist
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerTop = document.getElementById('hamburger-top');
  const hamburgerMid = document.getElementById('hamburger-mid');
  const hamburgerBottom = document.getElementById('hamburger-bottom');
  const navLinks = document.querySelectorAll('.nav-link');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

  // Navbar scroll effect
  function handleScroll() {
    if (window.scrollY > 20) {
      navbar?.classList.add('is-scrolled');
      navbar?.classList.remove('h-20');
      navbar?.classList.add('h-16');
      navbar?.querySelector('.max-w-7xl')?.classList.remove('h-20');
      navbar?.querySelector('.max-w-7xl')?.classList.add('h-16');
    } else {
      navbar?.classList.remove('is-scrolled');
      navbar?.classList.remove('h-16');
      navbar?.classList.add('h-20');
      navbar?.querySelector('.max-w-7xl')?.classList.remove('h-16');
      navbar?.querySelector('.max-w-7xl')?.classList.add('h-20');
    }

    // Active Section Highlighting
    const sections = ['top', 'services', 'how-it-works', 'why-choose-us', 'testimonials', 'pricing', 'faq', 'contact'];
    const currentPath = window.location.pathname;

    if (currentPath === '/about') {
       highlightLink('/about');
    } else {
      let currentSection = '';
      for (const section of sections) {
        const element = document.getElementById(section);
        if (element) {
          const rect = element.getBoundingClientRect();
          if (rect.top <= 100) {
            currentSection = section;
          }
        }
      }

      if (currentSection === 'top' || currentSection === '') {
        highlightLink('/#top');
      } else {
        highlightLink(`/#${currentSection}`);
      }
    }
  }

  function highlightLink(href: string) {
    navLinks.forEach(link => {
      const linkHref = link.getAttribute('data-href');
      const indicator = link.querySelector('.active-indicator');
      const isDropdownItem = link.closest('.dropdown-container') !== null;

      if (linkHref === href) {
        link.classList.add('text-indigo-600', 'dark:text-indigo-400');
        link.classList.remove('text-slate-600', 'dark:text-slate-400');
        indicator?.classList.remove('scale-x-0');
        indicator?.classList.add('scale-x-100');

        if (isDropdownItem) {
          const dropdownButton = link.closest('.dropdown-container')?.querySelector('button');
          dropdownButton?.classList.add('text-indigo-600', 'dark:text-indigo-400');
          dropdownButton?.classList.remove('text-slate-600', 'dark:text-slate-400');
        }
      } else {
        link.classList.remove('text-indigo-600', 'dark:text-indigo-400');
        link.classList.add('text-slate-600', 'dark:text-slate-400');
        indicator?.classList.add('scale-x-0');
        indicator?.classList.remove('scale-x-100');

        if (isDropdownItem) {
          const dropdownContainer = link.closest('.dropdown-container');
          const dropdownButton = dropdownContainer?.querySelector('button');
          const hasActiveChild = dropdownContainer?.querySelector('.nav-link.text-indigo-600');

          if (!hasActiveChild) {
            dropdownButton?.classList.remove('text-indigo-600', 'dark:text-indigo-400');
            dropdownButton?.classList.add('text-slate-600', 'dark:text-slate-400');
          }
        }
      }
    });
  }

  window.addEventListener('scroll', handleScroll);
  window.addEventListener('load', handleScroll);

  // Mobile menu toggle
  let isMenuOpen = false;
  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      mobileMenu?.classList.remove('translate-x-full');
      hamburgerTop?.classList.add('rotate-45', 'translate-y-2');
      hamburgerMid?.classList.add('opacity-0');
      hamburgerBottom?.classList.add('-rotate-45', '-translate-y-2');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu?.classList.add('translate-x-full');
      hamburgerTop?.classList.remove('rotate-45', 'translate-y-2');
      hamburgerMid?.classList.remove('opacity-0');
      hamburgerBottom?.classList.remove('-rotate-45', '-translate-y-2');
      document.body.style.overflow = '';
    }
  }

  mobileMenuButton?.addEventListener('click', toggleMenu);

  // Dropdown accessibility and interaction
  const dropdownContainers = document.querySelectorAll('.dropdown-container');
  dropdownContainers.forEach(container => {
    const button = container.querySelector('button');

    container.addEventListener('mouseenter', () => {
      button?.setAttribute('aria-expanded', 'true');
    });

    container.addEventListener('mouseleave', () => {
      button?.setAttribute('aria-expanded', 'false');
    });

    button?.addEventListener('focus', () => {
      button?.setAttribute('aria-expanded', 'true');
    });

    button?.addEventListener('blur', (e) => {
      const relatedTarget = (e as FocusEvent).relatedTarget as HTMLElement;
      if (!container.contains(relatedTarget)) {
        button?.setAttribute('aria-expanded', 'false');
      }
    });

    // Close dropdown when a link is clicked (especially for anchors)
    container.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        button?.setAttribute('aria-expanded', 'false');
        // Force blur to hide dropdown if focus-within was keeping it open
        (document.activeElement as HTMLElement)?.blur();
      });
    });
  });

  // Close mobile menu on link click
  mobileNavLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (isMenuOpen) toggleMenu();
    });
  });

  // Handle anchor clicks for smooth scroll on same page
  document.querySelectorAll('a[href^="/#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      const href = this.getAttribute('href');
      const targetId = href.split('#')[1];
      const targetElement = document.getElementById(targetId);
      const currentPath = window.location.pathname;

      if (currentPath === '/' && targetElement) {
        e.preventDefault();
        const navHeight = 64;
        const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset - navHeight;
        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth'
        });
        history.pushState(null, '', `/#${targetId}`);
      }
    });
  });
</script>

<style>
  .nav-link:hover .active-indicator {
    transform: scaleX(1) !important;
  }
</style>
