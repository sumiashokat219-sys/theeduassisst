---
const faqs = [
  { q: "How long does it take to build a course?", a: "Typically, a full course build takes between 4 to 8 weeks depending on the complexity and volume of content." },
  { q: "Do I need to be tech-savvy?", a: "Not at all. We handle all the technical implementation, from LMS setup to automation." },
  { q: "Which platforms do you support?", a: "We specialize in Kajabi, Thinkific, Teachable, and various WordPress-based LMS solutions." },
  { q: "Will I own all the content?", a: "Yes, you retain 100% ownership of all your intellectual property and course materials." }
];
---
<section id="faq" class="py-24 md:py-32 bg-slate-50/50">
   <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16 reveal-up">
        <h2 class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-4">FAQ</h2>
        <h3 class="text-3xl md:text-4xl font-bold text-slate-900">Common Questions</h3>
      </div>

      <div class="space-y-4">
         {faqs.map(faq => (
           <details class="group bg-white rounded-2xl border border-slate-100 overflow-hidden shadow-sm hover:shadow-md transition-all duration-300">
              <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                 <span class="text-lg font-bold text-slate-900">{faq.q}</span>
                 <span class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center group-open:rotate-180 transition-transform">
                    <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                 </span>
              </summary>
              <div class="px-6 pb-6 text-slate-600 leading-relaxed">
                 {faq.a}
              </div>
           </details>
         ))}
      </div>
   </div>
</section>
