---
interface Props {
  class?: string;
  size?: number;
}

const { class: className, size = 40 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  class={className}
  xmlns="http://www.w3.org/2000/svg"
  xmlns:xlink="http://www.w3.org/1999/xlink"
>
  <defs>
    <!-- Top text path (Center of green ring: radius 38) -->
    <path id="topPath" d="M 12,50 A 38,38 0 0,1 88,50" />
    <!-- Bottom text path (Center of green ring: radius 38, reversed for upright text) -->
    <path id="bottomPath" d="M 88,50 A 38,38 0 0,1 12,50" />
  </defs>

  <!-- Outer Borders and Rings -->
  <!-- Circle 1 (r=50, white border) -->
  <circle cx="50" cy="50" r="50" fill="white" />
  <!-- Circle 2 (r=47, green ring) -->
  <circle cx="50" cy="50" r="47" fill="#79B64A" />
  <!-- Circle 3 (r=29, white separator) -->
  <circle cx="50" cy="50" r="29" fill="white" />
  <!-- Circle 4 (r=26, blue inner circle) -->
  <circle cx="50" cy="50" r="26" fill="#214A72" />

  <!-- Circular Text -->
  <text
    fill="white"
    font-family="'Montserrat', sans-serif"
    font-weight="700"
    font-size="7.5"
    letter-spacing="0.6"
  >
    <textPath xlink:href="#topPath" startOffset="50%" text-anchor="middle" dominant-baseline="central">
      THEEDUASSIST
    </textPath>
  </text>

  <text
    fill="white"
    font-family="'Montserrat', sans-serif"
    font-weight="700"
    font-size="3.8"
    letter-spacing="0.3"
  >
    <textPath xlink:href="#bottomPath" startOffset="50%" text-anchor="middle" dominant-baseline="central">
      E-LEARNING DESIGN AGENCY
    </textPath>
  </text>

  <!-- Stars -->
  <text x="12" y="50" fill="white" font-size="7" text-anchor="middle" dominant-baseline="central" font-weight="bold">★</text>
  <text x="88" y="50" fill="white" font-size="7" text-anchor="middle" dominant-baseline="central" font-weight="bold">★</text>

  <!-- Center Icon Group (Flat Vector Style) -->
  <!-- 1. Technology Circuit Background (10 branches) -->
  <g stroke="white" stroke-width="0.5" opacity="0.3">
    <path d="M 38,38 L 43,43" />
    <path d="M 62,38 L 57,43" />
    <path d="M 38,62 L 43,57" />
    <path d="M 62,62 L 57,57" />
    <path d="M 32,50 L 40,50" />
    <path d="M 68,50 L 60,50" />
    <path d="M 50,32 L 50,40" />
    <path d="M 50,68 L 50,60" />
    <path d="M 40,32 L 44,38" />
    <path d="M 60,32 L 56,38" />

    <!-- Connection Nodes -->
    <circle cx="38" cy="38" r="0.8" fill="white" stroke="none" />
    <circle cx="62" cy="38" r="0.8" fill="white" stroke="none" />
    <circle cx="38" cy="62" r="0.8" fill="white" stroke="none" />
    <circle cx="62" cy="62" r="0.8" fill="white" stroke="none" />
    <circle cx="32" cy="50" r="0.8" fill="white" stroke="none" />
    <circle cx="68" cy="50" r="0.8" fill="white" stroke="none" />
    <circle cx="50" cy="32" r="0.8" fill="white" stroke="none" />
    <circle cx="50" cy="68" r="0.8" fill="white" stroke="none" />
    <circle cx="40" cy="32" r="0.8" fill="white" stroke="none" />
    <circle cx="60" cy="32" r="0.8" fill="white" stroke="none" />
  </g>

  <!-- 2. Graduation Cap (Top) -->
  <g fill="white">
    <path d="M 38,34 L 50,28 L 62,34 L 50,40 Z" />
    <path d="M 44,37 L 44,41 Q 50,43 56,41 L 56,37" />
    <line x1="62" y1="34" x2="62" y2="40" stroke="white" stroke-width="1" />
  </g>

  <!-- 3. Computer Monitor (Middle) -->
  <g fill="white">
    <rect x="37" y="44" width="26" height="14" rx="1" />
    <rect x="39" y="46" width="22" height="10" fill="#214A72" />
    <rect x="47" y="58" width="6" height="3" />
    <rect x="43" y="61" width="14" height="1.5" rx="0.5" />
  </g>

  <!-- 4. Open Book (Bottom) -->
  <g fill="white">
    <path d="M 33,65 Q 50,62 67,65 L 67,75 Q 50,72 33,75 Z" />
    <line x1="50" y1="65" x2="50" y2="75" stroke="#214A72" stroke-width="0.6" />
  </g>
</svg>
