---
interface Props {
  class?: string;
  size?: number;
}

const { class: className, size = 40 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  class={className}
  xmlns="http://www.w3.org/2000/svg"
  xmlns:xlink="http://www.w3.org/1999/xlink"
>
  <defs>
    <!-- Top text path (Center of green ring: radius 38, CW L-to-R) -->
    <path id="topPath" d="M 12,50 A 38,38 0 0,1 88,50" />
    <!-- Bottom text path (Center of green ring: radius 38, CCW L-to-R for upright orientation) -->
    <path id="bottomPath" d="M 12,50 A 38,38 0 0,0 88,50" />
  </defs>

  <!-- Outer White Border (3 units) -->
  <circle cx="50" cy="50" r="50" fill="white" />

  <!-- Outer Ring (Green - #79B64A) (18 units wide) -->
  <circle cx="50" cy="50" r="47" fill="#79B64A" />

  <!-- Inner White Border (3 units) -->
  <circle cx="50" cy="50" r="29" fill="white" />

  <!-- Inner Circle (Blue - #214A72) -->
  <circle cx="50" cy="50" r="26" fill="#214A72" />

  <!-- Circular Text -->
  <text
    fill="white"
    font-family="'Montserrat', sans-serif"
    font-weight="800"
    font-size="6.4"
    letter-spacing="0.8"
  >
    <textPath xlink:href="#topPath" startOffset="50%" text-anchor="middle" dominant-baseline="central">
      THEEDUASSIST
    </textPath>
  </text>

  <text
    fill="white"
    font-family="'Montserrat', sans-serif"
    font-weight="800"
    font-size="3.3"
    letter-spacing="0.4"
  >
    <textPath xlink:href="#bottomPath" startOffset="50%" text-anchor="middle" dominant-baseline="central" side="right">
      E-LEARNING DESIGN AGENCY
    </textPath>
  </text>

  <!-- Stars (5-point, Size 14) -->
  <!-- Left Star -->
  <polygon points="12,43 13.8,48.5 19,48.5 14.8,51.5 16.5,57 12,54 7.5,57 9.2,51.5 5,48.5 10.2,48.5" fill="white" />
  <!-- Right Star -->
  <polygon points="88,43 89.8,48.5 95,48.5 90.8,51.5 92.5,57 88,54 83.5,57 85.2,51.5 81,48.5 86.2,48.5" fill="white" />

  <!-- Center Icon Group -->
  <!-- 1. Technology Circuit (Background) -->
  <g stroke="white" stroke-width="0.4" opacity="0.4">
    <line x1="50" y1="50" x2="50" y2="28" />
    <line x1="50" y1="50" x2="63.5" y2="33.8" />
    <line x1="50" y1="50" x2="71" y2="43.5" />
    <line x1="50" y1="50" x2="69.5" y2="59.5" />
    <line x1="50" y1="50" x2="57.5" y2="70.5" />
    <line x1="50" y1="50" x2="42.5" y2="70.5" />
    <line x1="50" y1="50" x2="30.5" y2="59.5" />
    <line x1="50" y1="50" x2="29" y2="43.5" />
    <line x1="50" y1="50" x2="36.5" y2="33.8" />
    <line x1="50" y1="50" x2="50" y2="72" />

    <circle cx="50" cy="28" r="0.8" fill="white" stroke="none" />
    <circle cx="63.5" cy="33.8" r="0.8" fill="white" stroke="none" />
    <circle cx="71" cy="43.5" r="0.8" fill="white" stroke="none" />
    <circle cx="69.5" cy="59.5" r="0.8" fill="white" stroke="none" />
    <circle cx="57.5" cy="70.5" r="0.8" fill="white" stroke="none" />
    <circle cx="42.5" cy="70.5" r="0.8" fill="white" stroke="none" />
    <circle cx="30.5" cy="59.5" r="0.8" fill="white" stroke="none" />
    <circle cx="29" cy="43.5" r="0.8" fill="white" stroke="none" />
    <circle cx="36.5" cy="33.8" r="0.8" fill="white" stroke="none" />
    <circle cx="50" cy="72" r="0.8" fill="white" stroke="none" />
  </g>

  <!-- 2. Graduation Cap (Top Center) -->
  <g fill="white">
    <path d="M 38,36 L 50,31 L 62,36 L 50,41 Z" />
    <path d="M 43,38 L 43,41 Q 50,44 57,41 L 57,38" />
    <line x1="62" y1="36" x2="62" y2="42" stroke="white" stroke-width="0.8" />
  </g>

  <!-- 3. Computer Monitor (Middle) -->
  <g fill="white">
    <rect x="38" y="44" width="24" height="15" rx="1" fill="none" stroke="white" stroke-width="1" />
    <rect x="39.5" y="45.5" width="21" height="10" rx="0.5" opacity="0.4" />
    <path d="M 46,59 L 44,62 L 56,62 L 54,59 Z" />
  </g>

  <!-- 4. Open Book (Bottom Center) -->
  <g fill="white">
    <path d="M 35,64 Q 50,60 65,64 L 65,73 Q 50,69 35,73 Z" />
    <line x1="50" y1="64" x2="50" y2="73" stroke="#214A72" stroke-width="0.5" />
  </g>
</svg>
