---
interface Props {
  class?: string;
  size?: number;
}

const { class: className, size = 40 } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  class={className}
  xmlns="http://www.w3.org/2000/svg"
  xmlns:xlink="http://www.w3.org/1999/xlink"
>
  <defs>
    <!-- Top text path (Center of green ring: radius 38) -->
    <path id="topPath" d="M 12,50 A 38,38 0 0,1 88,50" />
    <!-- Bottom text path (Center of green ring: radius 38, CCW to keep text upright) -->
    <path id="bottomPath" d="M 12,50 A 38,38 0 0,0 88,50" />
  </defs>

  <!-- Outer Border (White) -->
  <circle cx="50" cy="50" r="50" fill="white" />

  <!-- Outer Ring (Green) -->
  <circle cx="50" cy="50" r="47" fill="#79B64A" />

  <!-- Inner Border (White) -->
  <circle cx="50" cy="50" r="29" fill="white" />

  <!-- Inner Circle (Navy) -->
  <circle cx="50" cy="50" r="26" fill="#214A72" />

  <!-- Circular Text -->
  <text
    fill="white"
    font-family="'Montserrat', 'Inter', system-ui, sans-serif"
    font-weight="800"
    font-size="7.2"
    letter-spacing="0.5"
  >
    <textPath xlink:href="#topPath" startOffset="50%" text-anchor="middle" dominant-baseline="central">
      THEEDUASSIST
    </textPath>
  </text>

  <text
    fill="white"
    font-family="'Montserrat', 'Inter', system-ui, sans-serif"
    font-weight="800"
    font-size="3.2"
    letter-spacing="0.3"
  >
    <textPath xlink:href="#bottomPath" startOffset="50%" text-anchor="middle" dominant-baseline="central">
      E-LEARNING DESIGN AGENCY
    </textPath>
  </text>

  <!-- Stars -->
  <text x="12" y="50" fill="white" font-size="6" text-anchor="middle" dominant-baseline="central" font-weight="bold">★</text>
  <text x="88" y="50" fill="white" font-size="6" text-anchor="middle" dominant-baseline="central" font-weight="bold">★</text>

  <!-- Center Icon Group -->
  <!-- 1. Circuit lines (Background) - 10 branches -->
  <g stroke="white" stroke-width="0.4" opacity="0.4" fill="none">
    <line x1="50" y1="50" x2="50" y2="28" />
    <line x1="50" y1="50" x2="33" y1="33" />
    <line x1="50" y1="50" x2="67" y1="33" />
    <line x1="50" y1="50" x2="30" y2="50" />
    <line x1="50" y1="50" x2="70" y2="50" />
    <line x1="50" y1="50" x2="35" y1="65" />
    <line x1="50" y1="50" x2="65" y1="65" />
    <line x1="50" y1="50" x2="42" y1="30" />
    <line x1="50" y1="50" x2="58" y1="30" />
    <line x1="50" y1="50" x2="50" y2="72" />

    <circle cx="50" cy="28" r="0.7" fill="white" stroke="none" />
    <circle cx="33" cy="33" r="0.7" fill="white" stroke="none" />
    <circle cx="67" cy="33" r="0.7" fill="white" stroke="none" />
    <circle cx="30" cy="50" r="0.7" fill="white" stroke="none" />
    <circle cx="70" cy="50" r="0.7" fill="white" stroke="none" />
    <circle cx="35" cy="65" r="0.7" fill="white" stroke="none" />
    <circle cx="65" cy="65" r="0.7" fill="white" stroke="none" />
    <circle cx="42" cy="30" r="0.7" fill="white" stroke="none" />
    <circle cx="58" cy="30" r="0.7" fill="white" stroke="none" />
    <circle cx="50" cy="72" r="0.7" fill="white" stroke="none" />
  </g>

  <!-- 2. Graduation Cap (Top) -->
  <g fill="white">
    <path d="M 38,32 L 50,26 L 62,32 L 50,38 Z" />
    <path d="M 43,34 L 43,37 Q 50,39 57,37 L 57,34" />
    <line x1="62" y1="32" x2="62" y2="38" stroke="white" stroke-width="0.8" />
  </g>

  <!-- 3. Computer Monitor (Middle) -->
  <g fill="white">
    <rect x="36" y="42" width="28" height="16" rx="1" />
    <rect x="38" y="44" width="24" height="11" fill="#214A72" />
    <rect x="47" y="58" width="6" height="2" />
    <rect x="43" y="60" width="14" height="1" />
  </g>

  <!-- 4. Open Book (Bottom) -->
  <g fill="white">
    <path d="M 34,64 Q 50,61 66,64 L 66,74 Q 50,71 34,74 Z" />
    <line x1="50" y1="64" x2="50" y2="74" stroke="#214A72" stroke-width="0.4" />
  </g>
</svg>
