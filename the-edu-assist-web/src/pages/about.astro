---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';

const values = [
  {
    title: "Learner-First Design",
    description: "We prioritize the student experience, ensuring every lesson is clear, actionable, and easy to digest.",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
  },
  {
    title: "Clear Course Structure",
    description: "A well-organized curriculum is the backbone of learning. We build logical paths to mastery.",
    icon: "M4 6h16M4 10h16M4 14h16M4 18h16"
  },
  {
    title: "Practical Learning",
    description: "We focus on outcomes. Our courses include worksheets, quizzes, and projects that drive results.",
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
  },
  {
    title: "Modern Technology",
    description: "We leverage the latest LMS platforms and AI tools to create high-production value efficiently.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  },
  {
    title: "Collaboration",
    description: "Your expertise, our structure. We work closely with you to capture your unique voice and wisdom.",
    icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
  },
  {
    title: "Continuous Improvement",
    description: "Education is iterative. We help you refine your course based on real learner feedback.",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
  }
];

const steps = [
  { name: "Discover", description: "We dive deep into your expertise and audience goals." },
  { name: "Plan", description: "Crafting the perfect curriculum map and learning path." },
  { name: "Design", description: "Creating visual assets and instructional materials." },
  { name: "Build", description: "Setting up the platform and uploading content." },
  { name: "Launch", description: "Deploying your course to the world with confidence." },
  { name: "Improve", description: "Analyzing data to refine the learning experience." }
];

const expertise = [
  { name: "Course Design", badge: "Core", icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
  { name: "Curriculum Strategy", badge: "Expert", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" },
  { name: "Kajabi", badge: "Platform", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  { name: "LMS", badge: "Technical", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" },
  { name: "AI Tools", badge: "Modern", icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.691.31a2 2 0 00-1.154 1.51l-.222 1.332a2 2 0 001.022 2.115l1.112.556a2 2 0 001.789 0l1.112-.556a2 2 0 001.022-2.115l-.222-1.332a2 2 0 00-.5-1.332l.001-.001zM10.5 5.5a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" },
  { name: "Learning Experience", badge: "Focus", icon: "M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" }
];
---

<Layout title="About Us | TheEduAssist - Premium Course Building Agency">
  <main class="overflow-hidden">

    <!-- 1. HERO SECTION -->
    <section class="relative pt-32 pb-24 md:pt-48 md:pb-40 overflow-hidden">
      <!-- Animated Background Blobs -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10">
        <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-indigo-100/50 blur-[120px] animate-blob"></div>
        <div class="absolute bottom-[10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-blue-100/50 blur-[100px] animate-blob animation-delay-2000"></div>
      </div>

      <div class="max-w-7xl mx-auto px-6 text-center">
        <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-indigo-50 border border-indigo-100 text-indigo-600 text-sm font-semibold mb-8 animate-fade-in">
          Our Mission & Vision
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-slate-900 mb-8 animate-fade-up">
          Empowering Experts to <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 via-blue-600 to-indigo-600 bg-[length:200%_auto] animate-gradient-text">Educate the World</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 max-w-3xl mx-auto mb-12 animate-fade-up animation-delay-200">
          TheEduAssist is a premium course-building agency helping creators transform their unique expertise into world-class digital learning experiences.
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center animate-fade-up animation-delay-300">
          <a href="/#services" class="px-10 py-5 bg-indigo-600 text-white font-bold rounded-2xl hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-200 hover:shadow-indigo-300 hover:-translate-y-1">
            Start Your Course Build
          </a>
          <a href="#story" class="px-10 py-5 bg-white text-slate-700 font-bold rounded-2xl border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all hover:-translate-y-1">
            Our Story
          </a>
        </div>

        <!-- Dashboard Mockup -->
        <div class="mt-24 relative animate-fade-up animation-delay-500">
          <div class="relative mx-auto max-w-5xl group">
             <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-blue-50 rounded-[2.5rem] blur opacity-20 group-hover:opacity-30 transition duration-1000 group-hover:duration-200"></div>
             <div class="relative bg-white rounded-[2rem] shadow-2xl border border-slate-100 overflow-hidden">
                <div class="bg-slate-50 border-b border-slate-100 px-6 py-4 flex items-center gap-3">
                  <div class="flex gap-1.5">
                    <div class="w-3 h-3 rounded-full bg-red-400"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400"></div>
                  </div>
                  <div class="h-6 w-64 bg-white rounded-lg border border-slate-200 ml-4"></div>
                </div>
                <div class="p-8 md:p-12">
                   <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                      <div class="space-y-6">
                        <div class="h-40 bg-indigo-50 rounded-2xl flex items-center justify-center">
                          <svg class="w-12 h-12 text-indigo-200" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"></path></svg>
                        </div>
                        <div class="space-y-3">
                          <div class="h-4 w-full bg-slate-100 rounded"></div>
                          <div class="h-4 w-2/3 bg-slate-100 rounded"></div>
                        </div>
                      </div>
                      <div class="md:col-span-2 space-y-8">
                        <div class="h-8 w-1/3 bg-indigo-100 rounded"></div>
                        <div class="space-y-4">
                          <div class="h-4 w-full bg-slate-50 rounded"></div>
                          <div class="h-4 w-full bg-slate-50 rounded"></div>
                          <div class="h-4 w-full bg-slate-50 rounded"></div>
                          <div class="h-4 w-3/4 bg-slate-50 rounded"></div>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                           <div class="h-24 bg-blue-50 rounded-xl"></div>
                           <div class="h-24 bg-indigo-50 rounded-xl"></div>
                        </div>
                      </div>
                   </div>
                </div>
             </div>
          </div>
          <!-- Floating shapes -->
          <div class="absolute -top-12 -right-12 w-32 h-32 bg-yellow-400/10 rounded-full blur-2xl animate-pulse"></div>
          <div class="absolute -bottom-12 -left-12 w-40 h-40 bg-indigo-600/10 rounded-full blur-3xl animate-pulse animation-delay-2000"></div>
        </div>

        <div class="mt-16 animate-bounce">
           <a href="#story" class="text-slate-400 hover:text-indigo-600 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
           </a>
        </div>
      </div>
    </section>

    <!-- 2. COMPANY STORY -->
    <section id="story" class="py-24 md:py-32 bg-white relative">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-20 items-center">
          <div class="reveal-left">
            <h2 class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-4">Our Origin</h2>
            <h3 class="text-4xl md:text-5xl font-bold text-slate-900 mb-8 leading-tight">
              Bridging the Gap Between <span class="text-indigo-600">Expertise</span> and <span class="text-blue-600">Education</span>.
            </h3>
            <div class="space-y-6 text-lg text-slate-600 leading-relaxed">
              <p>
                TheEduAssist was born from a simple observation: some of the world's most brilliant minds struggle to share their knowledge effectively. Great experts aren't always natural curriculum designers.
              </p>
              <p>
                We saw coaches overwhelmed by technology, consultants lost in content structure, and educators frustrated by low student completion rates. We knew there was a better way.
              </p>
              <p>
                Our mission is to democratize high-quality education by providing experts with the tools, structure, and technical support they need to create courses that truly transform lives.
              </p>
            </div>
          </div>
          <div class="relative reveal-right">
             <div class="bg-gradient-to-br from-indigo-50 to-blue-50 rounded-[3rem] p-8 border border-indigo-100">
                <div class="space-y-8">
                   {['2022', '2023', '2024'].map((year, i) => (
                     <div class="flex gap-6 items-start">
                        <div class="w-16 h-16 rounded-2xl bg-white shadow-sm flex items-center justify-center font-bold text-indigo-600 shrink-0 border border-indigo-50">
                          {year}
                        </div>
                        <div>
                          <h4 class="font-bold text-slate-900 text-xl mb-1">
                            {i === 0 ? "Founding" : i === 1 ? "Scaling" : "AI Integration"}
                          </h4>
                          <p class="text-slate-500">
                             {i === 0 ? "Started with a vision to help local consultants." : i === 1 ? "Expanded to support global creators on Kajabi." : "Leveraging modern AI to build faster and better."}
                          </p>
                        </div>
                     </div>
                   ))}
                </div>
             </div>
             <!-- Decorative -->
             <div class="absolute -z-10 -top-10 -right-10 w-48 h-48 bg-indigo-100 rounded-full blur-3xl opacity-60"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. VALUES SECTION -->
    <section class="py-24 md:py-32 bg-slate-50/50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-20 reveal-up">
          <h2 class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-4">Core Principles</h2>
          <h3 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">Values that Drive Results</h3>
          <p class="text-xl text-slate-500 max-w-2xl mx-auto">Our work is guided by a commitment to excellence and a passion for effective learning.</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {values.map((value) => (
            <div class="bg-white p-10 rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 group reveal-up">
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-50 to-blue-50 text-indigo-600 flex items-center justify-center mb-8 group-hover:scale-110 group-hover:rotate-3 transition-transform duration-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={value.icon} />
                </svg>
              </div>
              <h4 class="text-2xl font-bold text-slate-900 mb-4 group-hover:text-indigo-600 transition-colors">{value.title}</h4>
              <p class="text-slate-600 leading-relaxed">
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. WHY CHOOSE THEEDUASSIST -->
    <WhyChooseUs />

    <!-- 5. PROCESS TIMELINE -->
    <section class="py-24 md:py-32 bg-indigo-950 text-white relative overflow-hidden">
       <!-- Abstract background -->
       <div class="absolute top-0 right-0 w-1/2 h-full bg-indigo-900/50 -skew-x-12 translate-x-1/4"></div>

       <div class="max-w-7xl mx-auto px-6 relative z-10">
          <div class="text-center mb-20 reveal-up">
            <h2 class="text-indigo-400 font-bold tracking-widest uppercase text-sm mb-4">Our Method</h2>
            <h3 class="text-4xl md:text-5xl font-bold mb-6">From Idea to Launch</h3>
            <p class="text-xl text-indigo-200/70 max-w-2xl mx-auto">A structured path designed to eliminate overwhelm and maximize quality.</p>
          </div>

          <div class="relative">
             <!-- Vertical Line -->
             <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-0.5 bg-indigo-800/50 -translate-x-1/2 hidden md:block"></div>
             <!-- Progress Line (Animated) -->
             <div class="absolute left-8 md:left-1/2 top-0 w-0.5 bg-indigo-500 -translate-x-1/2 animate-grow-v hidden md:block origin-top h-full"></div>

             <div class="space-y-12">
                {steps.map((step, i) => (
                  <div class={`flex flex-col md:flex-row items-center gap-8 md:gap-0 ${i % 2 === 0 ? 'md:flex-row-reverse' : ''} reveal-up`}>
                    <div class="flex-1 w-full md:w-auto text-left md:text-right px-12">
                       <div class={i % 2 === 0 ? 'md:text-left' : 'md:text-right'}>
                          <h4 class="text-2xl font-bold mb-2">{step.name}</h4>
                          <p class="text-indigo-200/60 text-lg">{step.description}</p>
                       </div>
                    </div>
                    <div class="relative z-20 flex items-center justify-center">
                       <div class="w-16 h-16 rounded-full bg-indigo-600 border-4 border-indigo-950 flex items-center justify-center font-bold text-xl shadow-xl shadow-indigo-500/20 group-hover:scale-110 transition-transform">
                          {i + 1}
                       </div>
                    </div>
                    <div class="flex-1 hidden md:block"></div>
                  </div>
                ))}
             </div>
          </div>
       </div>
    </section>

    <!-- 6. STATISTICS SECTION -->
    <section class="py-20 bg-white border-y border-slate-100">
       <div class="max-w-7xl mx-auto px-6">
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-12">
             {[
               { label: "Course Frameworks", value: 100, suffix: "+", id: "stat-1" },
               { label: "Learning Experience", value: 98, suffix: "%", id: "stat-2" },
               { label: "Platform Setups", value: 50, suffix: "+", id: "stat-3" },
               { label: "Launch Support", value: "24/7", suffix: "", id: "stat-4" }
             ].map(stat => (
               <div class="text-center reveal-up">
                  <div class="text-4xl md:text-5xl font-black text-slate-900 mb-2">
                    <span class="counter" data-target={stat.value}>{typeof stat.value === 'number' ? 0 : stat.value}</span>{stat.suffix}
                  </div>
                  <div class="text-slate-500 font-medium uppercase tracking-wider text-sm">{stat.label}</div>
               </div>
             ))}
          </div>
       </div>
    </section>

    <!-- 7. TEAM / EXPERTISE SECTION -->
    <section class="py-24 md:py-32 bg-slate-50/30">
       <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-20 reveal-up">
            <h2 class="text-indigo-600 font-bold tracking-widest uppercase text-sm mb-4">Our Expertise</h2>
            <h3 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">World-Class Capabilities</h3>
            <p class="text-xl text-slate-500 max-w-2xl mx-auto">We combine technical mastery with educational science to deliver superior results.</p>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
             {expertise.map(skill => (
               <div class="bg-white p-6 rounded-3xl border border-slate-100 shadow-sm flex flex-col items-center justify-center text-center hover:shadow-lg hover:glow-indigo transition-all duration-300 reveal-up">
                  <div class="h-12 w-12 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600 mb-4">
                     <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d={skill.icon} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  </div>
                  <div class="font-bold text-slate-900 mb-1">{skill.name}</div>
                  <div class="text-[10px] font-bold uppercase tracking-widest text-indigo-400">{skill.badge}</div>
               </div>
             ))}
          </div>
       </div>
    </section>

    <!-- 8. TESTIMONIAL SECTION -->
    <Testimonials />

    <!-- 9. FAQ SECTION -->
    <FAQ />

    <!-- 10. FINAL CTA -->
    <section class="py-24 md:py-32 px-6">
       <div class="max-w-6xl mx-auto bg-gradient-to-br from-indigo-600 to-blue-700 rounded-[3.5rem] p-12 md:p-24 text-center text-white relative overflow-hidden reveal-up">
          <!-- Decorative blobs -->
          <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <div class="absolute bottom-0 left-0 w-64 h-64 bg-indigo-400/20 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

          <div class="relative z-10">
            <h2 class="text-4xl md:text-6xl font-black mb-8 leading-tight">
              Ready to build an online course <br class="hidden md:block" /> learners actually finish?
            </h2>
            <p class="text-xl text-indigo-100/80 mb-12 max-w-2xl mx-auto font-medium">
              Join dozens of experts who have scaled their impact with our premium course building services.
            </p>
            <div class="flex flex-col sm:flex-row gap-6 justify-center">
              <a href="/#services" class="px-10 py-5 bg-white text-indigo-600 font-black rounded-2xl hover:bg-indigo-50 transition-all shadow-xl hover:-translate-y-1">
                Start Your Course Build
              </a>
              <a href="mailto:Info@theeduassist.com" class="px-10 py-5 bg-indigo-500/30 text-white font-black rounded-2xl border border-white/20 hover:bg-indigo-500/50 transition-all backdrop-blur-sm hover:-translate-y-1">
                Book a Free Consultation
              </a>
            </div>
          </div>
       </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  @keyframes blob {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 { animation-delay: 2s; }
  .animation-delay-3000 { animation-delay: 3s; }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes grow-v {
    from { transform: scaleY(0); }
    to { transform: scaleY(1); }
  }
  @keyframes gradient-text {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .animate-fade-in { animation: fade-in 1s ease-out forwards; }
  .animate-fade-up { opacity: 0; animation: fade-up 1s ease-out forwards; }
  .animate-grow-v { animation: grow-v 2s ease-out forwards; }
  .animate-gradient-text { animation: gradient-text 3s linear infinite; }

  .animation-delay-200 { animation-delay: 0.2s; }
  .animation-delay-300 { animation-delay: 0.3s; }
  .animation-delay-500 { animation-delay: 0.5s; }

  .glow-indigo:hover {
    box-shadow: 0 0 20px rgba(79, 70, 229, 0.2);
  }
</style>
