    </section>

    <!-- 8. FINAL CTA -->
    <section class="py-24 md:py-32 bg-white dark:bg-slate-950 transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-6">
        <div class="relative bg-gradient-to-br from-indigo-600 to-blue-700 rounded-[4rem] p-12 md:p-24 overflow-hidden text-center reveal-up">
           <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
           <div class="relative z-10 max-w-3xl mx-auto">
             <h2 class="text-4xl md:text-6xl font-bold text-white mb-8 leading-tight">Ready to Build Your Digital Legacy?</h2>
             <p class="text-xl text-indigo-100 mb-12 opacity-90">Book a free strategy session today and let's map out your path to a premium online course.</p>
             <div class="flex flex-col sm:flex-row gap-6 justify-center">
                <a href="/#contact" class="px-12 py-6 bg-white text-indigo-600 font-extrabold rounded-2xl hover:shadow-2xl transition-all hover:-translate-y-1 text-lg">
                  Book Free Consultation
                </a>
                <a href="mailto:hello@theeduassist.com" class="px-12 py-6 bg-transparent text-white border-2 border-white/20 font-extrabold rounded-2xl hover:bg-white/10 transition-all text-lg">
