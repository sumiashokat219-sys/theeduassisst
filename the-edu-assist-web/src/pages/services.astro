            </h4>
            <div class="space-y-8">
              {comparison.map((row) => (
                <div class="pb-8 border-b border-slate-200 dark:border-slate-800 last:border-0">
                  <div class="text-sm font-bold text-slate-400 dark:text-slate-500 uppercase tracking-widest mb-2">{row.feature}</div>
                  <div class="text-lg text-slate-500 dark:text-slate-400 font-medium">{row.without}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- The New Way -->
          <div class="p-10 md:p-16 rounded-[3rem] bg-indigo-600 text-white shadow-2xl shadow-indigo-200 relative overflow-hidden reveal-right">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
            <h4 class="text-2xl font-bold text-indigo-200 mb-10 flex items-center gap-3 relative z-10">
              <span class="w-8 h-8 rounded-full bg-white text-indigo-600 flex items-center justify-center text-sm">✓</span>
              With TheEduAssist
            </h4>
            <div class="space-y-8 relative z-10">
              {comparison.map((row) => (
                <div class="pb-8 border-b border-indigo-500/30 last:border-0">
                  <div class="text-sm font-bold text-indigo-300 uppercase tracking-widest mb-2">{row.feature}</div>
                  <div class="text-xl font-bold">{row.with}</div>
                </div>
              ))}
            </div>

            <div class="mt-12 p-8 rounded-2xl bg-white/10 border border-white/10 backdrop-blur-sm relative z-10">
               <div class="text-indigo-200 text-sm font-bold mb-2">THE RESULT</div>
               <div class="text-2xl font-bold">A premium educational asset that scales.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. FAQ -->
    <section id="faq" class="py-24 md:py-32 bg-slate-50/50 dark:bg-slate-900/50 transition-colors duration-300">
      <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-20 reveal-up">
          <h2 class="text-indigo-600 dark:text-indigo-400 font-bold tracking-widest uppercase text-sm mb-4">FAQ</h2>
          <h3 class="text-4xl md:text-5xl font-bold text-slate-900 dark:text-white mb-6">Service Questions</h3>
        </div>

        <div class="space-y-4">
          {faqs.map((faq, i) => (
            <div class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-100 dark:border-slate-800 overflow-hidden reveal-up" style={`transition-delay: ${i * 100}ms`}>
              <details class="group">
                <summary class="flex items-center justify-between p-8 cursor-pointer list-none">
                  <h4 class="text-xl font-bold text-slate-900 dark:text-white">{faq.q}</h4>
                  <span class="transition-transform duration-300 group-open:rotate-180">
                    <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                  </span>
                </summary>
                <div class="px-8 pb-8 text-slate-500 dark:text-slate-400 leading-relaxed">
